{
  "name": "oprcli",
  "version": "2.0.7",
  "description": "统一 AI CLI 连接器服务器 - 支持 Claude Code、IFlow 和 Agent",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "check-deps": "node scripts/check-deps.js",
    "validate-env": "node scripts/validate-env.js",
    "diagnose": "node scripts/diagnose.js",
    "view-logs": "node scripts/view-logs.js",
    "audit": "npm audit",
    "audit:fix": "npm audit fix",
    "outdated": "npm outdated",
    "analyze": "node scripts/performance-analyzer.js",
    "health": "node scripts/dependency-health-check.js",
    "health:fix": "node scripts/dependency-health-check.js --fix",
    "version:check": "node scripts/version-manager.js --check",
    "version:bump": "node scripts/version-manager.js --bump",
    "project:health": "node scripts/project-health.js",
    "news:collect": "node scripts/news-collector.js",
    "news:test": "node scripts/news-collector.js --test"
  },
  "keywords": [
    "claude",
    "claude-code",
    "iflow",
    "anthropic",
    "ai",
    "cli",
    "connector",
    "dingtalk",
    "钉钉",
    "unified",
    "agent",
    "llm",
    "tools"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=14.0.0"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "compression": "^1.7.4",
    "dingtalk-stream": "^2.1.4",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "form-data": "^4.0.5",
    "glob": "^10.3.0",
    "helmet": "^7.1.0",
    "node-cron": "^3.0.3",
    "silk-wasm": "^3.7.1",
    "wav": "^1.0.2"
  }
}
