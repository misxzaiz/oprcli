# Agent Connector 配置示例
# 将此配置添加到你的 .env 文件中

# ==================== Agent 配置 ====================
# 启用 Agent Connector
AGENT_ENABLED=true

# Agent 使用的 LLM Provider 类型
# 可选值: iflow, deepseek, openai
AGENT_PROVIDER_TYPE=iflow

# LLM API Key
# iFlow: 从 https://iflow.cn 获取
# DeepSeek: 从 https://platform.deepseek.com 获取
# OpenAI: 从 https://platform.openai.com 获取
AGENT_API_KEY=sk-your-api-key-here

# 使用的模型名称
# iFlow: tstars2.0
# DeepSeek: deepseek-chat
# OpenAI: gpt-3.5-turbo, gpt-4 等
AGENT_MODEL=tstars2.0
