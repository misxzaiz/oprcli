      "enabled": true,
      "comment": "DeepSeek - 高性价比的国产大模型"
    },
    {
      "id": "openai",
      "type": "openai",
      "apiKey": "YOUR_OPENAI_API_KEY",
      "baseUrl": "https://api.openai.com/v1",
      "model": "gpt-3.5-turbo",
      "enabled": false,
      "comment": "OpenAI GPT - 经典的大语言模型"
    }
