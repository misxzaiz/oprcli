{
  "iflowPath": "iflow",
  "workDir": "D:\\MyProject",
  "includeDirectories": [
    "D:\\tmp",
    "E:\\shared"
  ],

  "dingtalk": {
    "clientId": "dingxxxxxxxxxxxxxxxx",
    "clientSecret": "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
    "enabled": true,

    "streaming": {
      "enabled": true,
      "mode": "realtime",
      "sendInterval": 2000,
      "maxOutputLength": 500,
      "showThinking": true,
      "showTools": true,
      "showTime": true
    },

    "logging": {
      "level": "EVENT",
      "colored": true,
      "file": null
    }
  }
}
