# OPRCLI 环境变量示例
# 复制为 .env 后按需修改。

# ========================
# 核心配置
# ========================
PROVIDER=claude
PORT=3000

# ========================
# 工作目录配置（新增）
# ========================
# 默认工作目录（所有provider共享，未单独配置时使用）
DEFAULT_WORK_DIR=/path/to/your/project

# Agent 工作目录（可选，未设置则使用 DEFAULT_WORK_DIR）
# AGENT_WORK_DIR=D:/space

# ========================
# Claude 配置
# ========================
CLAUDE_CMD_PATH=C:/Users/[你的用户名]/AppData/Roaming/npm/claude.cmd
# Claude 工作目录（可选，未设置则使用 DEFAULT_WORK_DIR）
# CLAUDE_WORK_DIR=/path/to/project
CLAUDE_GIT_BIN_PATH=C:/Program Files/Git/usr/bin/bash.exe

# ========================
# IFlow 配置
# ========================
IFLOW_PATH=C:/Users/[你的用户名]/AppData/Roaming/npm/iflow.cmd
# IFlow 工作目录（可选，未设置则使用 DEFAULT_WORK_DIR）
# IFLOW_WORK_DIR=/path/to/project
IFLOW_INCLUDE_DIRS=src,lib

# ========================
# Codex 配置
# ========================
CODEX_PATH=C:/Users/[你的用户名]/AppData/Roaming/npm/codex.cmd
# Codex 工作目录（可选，未设置则使用 DEFAULT_WORK_DIR）
# CODEX_WORK_DIR=/path/to/project
CODEX_SYSTEM_PROMPT_FILE=./system-prompts/codex.txt
CODEX_MODEL=gpt-5-codex
CODEX_MODEL_PROVIDER=custom
CODEX_MAX_HISTORY_LENGTH=20

# ========================
# 钉钉集成
# ========================
DINGTALK_CLIENT_ID=your-client-id
DINGTALK_CLIENT_SECRET=your-client-secret

# ========================
# QQ Bot 集成
# ========================
QQBOT_APP_ID=your-qqbot-app-id
QQBOT_CLIENT_SECRET=your-qqbot-client-secret
QQBOT_SANDBOX=false
QQBOT_DEBUG=false
QQBOT_COMMAND_PREFIX=/

# ========================
# 百度语音识别
# ========================
BAIDU_SPEECH_API_KEY=your-baidu-api-key
BAIDU_SPEECH_SECRET_KEY=your-baidu-secret-key

# ========================
# 提示词系统
# ========================
# 可选：全局和 provider 专用覆盖
SYSTEM_PROMPT=你是一个可靠、务实的助手。请先给结论，再给可执行步骤；不确定时明确说明。
CLAUDE_SYSTEM_PROMPT=
IFLOW_SYSTEM_PROMPT=
CODEX_SYSTEM_PROMPT=
SYSTEM_PROMPTS_DIR=./system-prompts

# 会话模式（universal/dev/ops）
# 模式提示词文件：
# - system-prompts/oprcli.universal.md
# - system-prompts/oprcli.dev.md
# - system-prompts/oprcli.ops.md
PROMPT_MODE=universal
PROMPT_CHANNEL_AWARE=true
PROMPT_INCLUDE_SOURCE_CONTEXT=true

# ========================
# 流式输出
# ========================
STREAM_ENABLED=true
STREAM_INTERVAL=2000
STREAM_MAX_LENGTH=5000
STREAM_SHOW_THINKING=true
STREAM_SHOW_TOOLS=true
STREAM_SHOW_TIME=true
STREAM_USE_MARKDOWN=false

# ========================
# 日志
# ========================
LOG_LEVEL=EVENT
LOG_COLORED=true
STRUCTURED_LOGGING=false

# ========================
# 通知
# ========================
NOTIFICATION_ENABLED=false
NOTIFICATION_TYPE=dingtalk
NOTIFICATION_DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=xxx
NOTIFICATION_DINGTALK_SECRET=SECxxxxxxxx

# ========================
# 定时任务
# ========================
TASKS_FILE_PATH=./scheduler/tasks.json

# ========================
# 审计日志（原始消息追踪）
# ========================
AUDIT_LOG_ENABLED=true
AUDIT_LOG_DIR=./logs
AUDIT_LOG_AGENT_IO=true
AUDIT_LOG_BOT_TRANSFORM=true
AUDIT_LOG_MAX_FIELD_LENGTH=8000
AUDIT_LOG_REDACT_KEYS=clientSecret,token,authorization,webhook,secret

# ========================
# 机器人过程输出（发送到QQ/钉钉）
# ========================
ROBOT_OUTPUT_ENABLED=true
ROBOT_OUTPUT_PROFILE=standard
ROBOT_SHOW_TYPES=assistant_chunk,result,thinking_exposed,tool_use,tool_result,http_request,http_response,error,end
ROBOT_SHOW_THINKING=true
ROBOT_SHOW_NETWORK=true
ROBOT_END_SUMMARY=true
ROBOT_MAX_CHARS=1200
ROBOT_DEDUP_WINDOW_MS=5000
ROBOT_CHUNK_STRATEGY=throttle
