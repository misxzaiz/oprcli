# OPRCLI 环境变量配置示例
# 复制此文件为 .env 并设置实际值
# 生成时间: 2026-03-05T08:33:12.599Z

# 核心配置
# AI 提供商 (claude/iflow)
PROVIDER=claude

# 服务器端口
PORT=13579

# Claude 配置
# Claude CLI 命令路径
CLAUDE_CMD_PATH=D:/path/to/claude.exe

# Claude 工作目录
CLAUDE_WORK_DIR=D:/space/oprcli

# Git 可执行文件路径
CLAUDE_GIT_BIN_PATH=C:/Program Files/Git/bin/git.exe

# Claude 系统提示词
CLAUDE_SYSTEM_PROMPT=You are a helpful assistant...

# IFlow 配置
# IFlow 命令路径
IFLOW_PATH=iflow

# IFlow 工作目录
IFLOW_WORK_DIR=D:/space/workspace

# IFlow 包含目录（逗号分隔）
IFLOW_INCLUDE_DIRS=src,lib

# IFlow 系统提示词
IFLOW_SYSTEM_PROMPT=You are a helpful assistant...

# Codex 配置
# Codex CLI 命令路径
CODEX_PATH=codex

# Codex 工作目录
CODEX_WORK_DIR=D:/space/workspace

# Codex 系统提示词文件
CODEX_SYSTEM_PROMPT_FILE=./system-prompts/codex.txt

# Codex 模型配置
CODEX_MODEL=gpt-5-codex
CODEX_MODEL_PROVIDER=anyrouter

# Codex 对话历史最大轮数（每轮包括用户和助手消息）
CODEX_MAX_HISTORY_LENGTH=20

# 钉钉配置
# 钉钉客户端 ID
DINGTALK_CLIENT_ID=your-client-id

# 钉钉客户端密钥
DINGTALK_CLIENT_SECRET=your-client-secret

# 提示词配置
# 提示词模式 (full/slim)
PROMPT_MODE=full

# 全局系统提示词
SYSTEM_PROMPT=You are a helpful assistant...

# 系统提示词目录
SYSTEM_PROMPTS_DIR=./system-prompts

# 流式输出配置
# 启用流式输出
STREAM_ENABLED=true

# 流式输出模式
STREAM_MODE=realtime

# 流式输出间隔（毫秒）
STREAM_INTERVAL=2000

# 流式输出最大长度
STREAM_MAX_LENGTH=5000

# 显示思考过程
STREAM_SHOW_THINKING=true

# 显示工具调用
STREAM_SHOW_TOOLS=true

# 显示时间戳
STREAM_SHOW_TIME=true

# 显示完成摘要
STREAM_SHOW_COMPLETION=true

# 去重 result 事件
STREAM_DEDUPLICATE_RESULT=true

# 使用 Markdown 格式
STREAM_USE_MARKDOWN=false

# 日志配置
# 日志级别
LOG_LEVEL=EVENT

# 彩色日志输出
LOG_COLORED=true

# 通知配置
# 启用通知
NOTIFICATION_ENABLED=false

# 通知类型
NOTIFICATION_TYPE=dingtalk

# 钉钉通知 Webhook
NOTIFICATION_DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=xxx

# 钉钉通知密钥
NOTIFICATION_DINGTALK_SECRET=SECxxxxxxxx

# 缓存配置
# 启用缓存
CACHE_ENABLED=true

# 缓存 TTL（毫秒）
CACHE_TTL=60000

# 最大缓存条目
CACHE_MAX_ENTRIES=1000

# 内存监控配置
# 启用内存监控
MEMORY_MONITOR_ENABLED=true

# 内存监控间隔（毫秒）
MEMORY_MONITOR_INTERVAL=60000

# 内存阈值（字节）
MEMORY_THRESHOLD=524288000

# 内存告警冷却时间（毫秒）
MEMORY_ALERT_COOLDOWN=300000

# 安全配置
# 启用 CORS
CORS_ENABLED=false

# CORS 允许来源
CORS_ORIGIN=*

# CORS 允许方法（逗号分隔）
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS

# CORS 允许头（逗号分隔）
CORS_HEADERS=Content-Type,Authorization

# CORS 允许凭证
CORS_CREDENTIALS=false

# 优雅关闭配置
# 优雅关闭超时（毫秒）
SHUTDOWN_TIMEOUT=30000

# 会话持久化配置
# 可选值: sqlite / json
SESSION_STORE_DRIVER=sqlite

# SQLite 数据文件（SESSION_STORE_DRIVER=sqlite 生效）
SESSION_STORE_SQLITE_PATH=./data/oprcli.db

# JSON 文件路径（sqlite 不可用或 driver=json 时生效）
SESSION_STORE_JSON_PATH=./data/dingtalk-sessions.json
