# ==========================================
# 核心配置
# ==========================================
# 提供商选择：claude | iflow
PROVIDER=claude

# 服务器端口
PORT=3000

# ==========================================
# Claude Code 配置
# ==========================================
# Claude CLI 命令路径（Windows 使用双反斜杠）
CLAUDE_CMD_PATH=C:\\Users\\YourName\\AppData\\Roaming\\npm\\claude.cmd

# 工作目录（项目路径）
CLAUDE_WORK_DIR=D:\\MyProject

# Git 可执行文件路径（可选，Windows 推荐）
CLAUDE_GIT_BIN_PATH=C:\\Program Files\\Git\\bin\\bash.exe

# ==========================================
# IFlow 配置（备用）
# ==========================================
# IFlow CLI 命令路径
IFLOW_PATH=iflow

# 工作目录
IFLOW_WORK_DIR="D:\MyProject"

# 包含的目录（逗号分隔）
IFLOW_INCLUDE_DIRS="D:\tmp1,D:\tmp2"

# ==========================================
# 钉钉 Stream 配置
# ==========================================
# 钉钉应用 Client ID
DINGTALK_CLIENT_ID=dingj3kvwt3xqflpb6dz

# 钉钉应用 Client Secret
DINGTALK_CLIENT_SECRET=your-client-secret-here

# ==========================================
# 流式输出配置
# ==========================================
# 是否启用流式输出
STREAM_ENABLED=true

# 流式模式：realtime | batch
STREAM_MODE=realtime

# 发送间隔（毫秒）
STREAM_INTERVAL=2000

# 最大输出长度
STREAM_MAX_LENGTH=5000

# 显示思考过程
STREAM_SHOW_THINKING=true

# 显示工具调用
STREAM_SHOW_TOOLS=true

# 显示时间
STREAM_SHOW_TIME=true

# 显示完成总结（在响应结束时发送统计信息）
STREAM_SHOW_COMPLETION=true

# 去重 result 事件（如果 result 与 assistant 内容相同则跳过）
STREAM_DEDUPLICATE_RESULT=true

# 使用 Markdown 格式
STREAM_USE_MARKDOWN=false

# ==========================================
# 日志配置
# ==========================================
# 日志级别：DEBUG | INFO | EVENT | SUCCESS | WARNING | ERROR
LOG_LEVEL=EVENT

# 彩色日志
LOG_COLORED=true
