# OPRCLI environment example
# Copy this file to .env and update values.

# ========================
# Core
# ========================
PROVIDER=claude
PORT=13579

# ========================
# Claude
# ========================
CLAUDE_CMD_PATH=D:/path/to/claude.exe
CLAUDE_WORK_DIR=D:/space/oprcli
CLAUDE_GIT_BIN_PATH=C:/Program Files/Git/bin/git.exe

# ========================
# IFlow
# ========================
IFLOW_PATH=iflow
IFLOW_WORK_DIR=D:/space/workspace
IFLOW_INCLUDE_DIRS=src,lib

# ========================
# Codex
# ========================
CODEX_PATH=codex
CODEX_WORK_DIR=D:/space/workspace
CODEX_SYSTEM_PROMPT_FILE=./system-prompts/codex.txt
CODEX_MODEL=gpt-5-codex
CODEX_MODEL_PROVIDER=anyrouter
CODEX_MAX_HISTORY_LENGTH=20

# ========================
# DingTalk Integration
# ========================
DINGTALK_CLIENT_ID=your-client-id
DINGTALK_CLIENT_SECRET=your-client-secret

# ========================
# QQ Bot Integration
# ========================
QQBOT_APP_ID=your-qqbot-app-id
QQBOT_CLIENT_SECRET=your-qqbot-client-secret
QQBOT_SANDBOX=false
QQBOT_DEBUG=false
QQBOT_COMMAND_PREFIX=/

# ========================
# Prompt System
# ========================
# Optional global and provider-specific prompt overrides
SYSTEM_PROMPT=You are a helpful assistant...
CLAUDE_SYSTEM_PROMPT=You are a helpful assistant...
IFLOW_SYSTEM_PROMPT=You are a helpful assistant...
CODEX_SYSTEM_PROMPT=You are a helpful assistant...
SYSTEM_PROMPTS_DIR=./system-prompts

# Conversation mode (universal/dev/ops)
PROMPT_MODE=universal
PROMPT_CHANNEL_AWARE=true
PROMPT_INCLUDE_SOURCE_CONTEXT=true

# ========================
# Streaming Behavior
# ========================
STREAM_ENABLED=true
STREAM_INTERVAL=2000
STREAM_MAX_LENGTH=5000
STREAM_SHOW_THINKING=true
STREAM_SHOW_TOOLS=true
STREAM_SHOW_TIME=true
STREAM_USE_MARKDOWN=false

# ========================
# Logging
# ========================
LOG_LEVEL=EVENT
LOG_COLORED=true
STRUCTURED_LOGGING=false

# ========================
# Notification
# ========================
NOTIFICATION_ENABLED=false
NOTIFICATION_TYPE=dingtalk
NOTIFICATION_DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=xxx
NOTIFICATION_DINGTALK_SECRET=SECxxxxxxxx

# ========================
# Scheduler
# ========================
TASKS_FILE_PATH=./scheduler/tasks.json

# ========================
# Optional Agent Framework (agents/*)
# ========================
DEFAULT_AGENT=claude-code
CLAUDE_CONFIG_PATH=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
