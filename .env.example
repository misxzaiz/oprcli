# ==========================================
# 核心配置
# ==========================================
# 提供商选择：claude | iflow
PROVIDER=claude

# 服务器端口
PORT=3000

# ==========================================
# Claude Code 配置
# ==========================================
# Claude CLI 命令路径（Windows 使用双反斜杠）
CLAUDE_CMD_PATH=C:\\Users\\YourName\\AppData\\Roaming\\npm\\claude.cmd

# 工作目录（项目路径）
CLAUDE_WORK_DIR=D:\\MyProject

# Git 可执行文件路径（可选，Windows 推荐）
CLAUDE_GIT_BIN_PATH=C:\\Program Files\\Git\\bin\\bash.exe

# ==========================================
# IFlow 配置（备用）
# ==========================================
# IFlow CLI 命令路径
IFLOW_PATH=iflow

# 工作目录
IFLOW_WORK_DIR="D:\MyProject"

# 包含的目录（逗号分隔）
IFLOW_INCLUDE_DIRS="D:\tmp1,D:\tmp2"

# ==========================================
# 钉钉 Stream 配置
# ==========================================
# 钉钉应用 Client ID
DINGTALK_CLIENT_ID=dingj3kvwt3xqflpb6dz

# 钉钉应用 Client Secret
DINGTALK_CLIENT_SECRET=your-client-secret-here

# ==========================================
# 流式输出配置
# ==========================================
# 是否启用流式输出
STREAM_ENABLED=true

# 流式模式：realtime | batch
STREAM_MODE=realtime

# 发送间隔（毫秒）
STREAM_INTERVAL=2000

# 最大输出长度
STREAM_MAX_LENGTH=5000

# 显示思考过程
STREAM_SHOW_THINKING=true

# 显示工具调用
STREAM_SHOW_TOOLS=true

# 显示时间
STREAM_SHOW_TIME=true

# 显示完成总结（在响应结束时发送统计信息）
STREAM_SHOW_COMPLETION=true

# 去重 result 事件（如果 result 与 assistant 内容相同则跳过）
STREAM_DEDUPLICATE_RESULT=true

# 使用 Markdown 格式
STREAM_USE_MARKDOWN=false

# ==========================================
# 日志配置
# ==========================================
# 日志级别：DEBUG | INFO | EVENT | SUCCESS | WARNING | ERROR
LOG_LEVEL=EVENT

# 彩色日志
LOG_COLORED=true

# ==========================================
# 系统提示词配置
# ==========================================
# 全局系统提示词（作为默认值，所有模型共用）
# 支持使用 \n 表示换行
# SYSTEM_PROMPT=你是一个专业的编程助手，请用简洁清晰的语言回答问题。

# Claude 专用系统提示词（优先级高于全局）
# CLAUDE_SYSTEM_PROMPT=你是 Claude，专注于代码生成和技术问答。

# IFlow 专用系统提示词（优先级高于全局）
# IFLOW_SYSTEM_PROMPT=你是心流 AI，专注于中文编程场景。

# 提示词配置文件路径（可选，优先级：环境变量 > 配置文件）
# SYSTEM_PROMPTS_DIR=./system-prompts

# ==========================================
# 通知配置
# ==========================================
# 通知功能开关
NOTIFICATION_ENABLED=true

# 通知类型（dingtalk, wecom, feishu）
NOTIFICATION_TYPE=dingtalk

# 钉钉机器人配置
# 获取方式：钉钉群 -> 群设置 -> 智能群助手 -> 添加机器人 -> 自定义
NOTIFICATION_DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=YOUR_TOKEN

# 钉钉机器人加签密钥（可选，如果启用了加签验证）
NOTIFICATION_DINGTALK_SECRET=SECxxxxxxxxx

# 默认消息类型（text, markdown）
NOTIFICATION_DEFAULT_TYPE=text

# 是否记录通知历史
NOTIFICATION_LOG_ENABLED=true
NOTIFICATION_LOG_FILE=logs/notifications.log
